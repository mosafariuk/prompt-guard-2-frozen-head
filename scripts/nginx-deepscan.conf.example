# Optional reverse proxy for the Tier-3a deep-scan service.
# The container is bound to 127.0.0.1:8080 (never public). Drop this server block
# into nginx / aaPanel to expose it on a domain WITH TLS. The service still enforces
# its own X-Edge-Auth shared secret, so the proxy is transport, not the trust root.
#
# SECURITY NOTES:
#   - Keep TLS on (Let's Encrypt via aaPanel). Never expose over plain HTTP.
#   - Optionally restrict `allow`/`deny` to the origin/edge egress IPs for defense
#     in depth, on top of the X-Edge-Auth secret.
#   - Do NOT log request bodies here (they may contain payloads); default nginx
#     access_log does not log bodies, which is correct.

server {
    listen 443 ssl http2;
    server_name deepscan.example.com;                # <-- your domain

    ssl_certificate     /etc/letsencrypt/live/deepscan.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/deepscan.example.com/privkey.pem;

    # Only the scan endpoint + health are proxied; everything else 404s.
    location = /v1/deep-scan {
        # Optional IP allowlist (edge/origin egress). Uncomment + set:
        # allow 203.0.113.10;   # your edge/origin egress IP
        # deny all;

        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Pass the caller's X-Edge-Auth straight through to the service.
        proxy_set_header X-Edge-Auth       $http_x_edge_auth;
        proxy_read_timeout 30s;
        client_max_body_size 256k;                   # bound request size at the edge
    }

    location = /health {
        proxy_pass http://127.0.0.1:8080;
    }

    location / { return 404; }
}
